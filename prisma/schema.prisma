generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                    String        @id @default(uuid())
  nombaVirtualAccountId String
  bankAccountNumber     String?
  bankName              String?
  bankAccountName       String?
  customerName          String
  accountRef            String        @unique
  expectedAmount        Int?
  expiryDate            DateTime?
  status                String        @default("active")
  createdAt             DateTime      @default(now())
  transactions          Transaction[]
}

model Transaction {
  id                  String    @id @default(uuid())
  accountId           String
  merchantTxRef       String    @unique
  sessionId           String?
  amount              Int
  direction           String
  state               String    @default("initiated")
  settlementMatch     String?
  failureReason       String?
  senderAccountName   String?
  senderAccountNumber String?
  senderBankCode      String?
  createdAt           DateTime  @default(now())
  lastCheckedAt       DateTime?
  requeueCount        Int       @default(0)
  account             Account   @relation(fields: [accountId], references: [id])

  @@index([state])
  @@index([accountId])
  @@index([merchantTxRef])
}

model AuditLog {
  id             String   @id @default(uuid())
  sequenceNumber Int      @unique
  eventType      String
  // Stored as the exact JSON string that was hashed, not `Json`/jsonb —
  // Postgres jsonb does not preserve key order/whitespace on write, so
  // re-serializing a jsonb column on read produces a different string than
  // the one hashed at write time and permanently breaks verifyAuditChain().
  payload        String   @db.Text
  previousHash   String
  hash           String
  timestamp      DateTime @default(now())
}
